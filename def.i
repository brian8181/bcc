  template <typename Base>
  parser::basic_symbol<Base>::basic_symbol (const basic_symbol& that)
    : Base (that)
    , value ()
  {
    switch (this->kind ())
    {
      case symbol_kind::S_assign_expr:
        value.copy< std::pair<std::string, std::string> > (std::move (that.value));
        break;

      case symbol_kind::S_stmts:
      case symbol_kind::S_params:
        value.copy< std::vector< std::string > > (std::move (that.value));
        break;

      case symbol_kind::S_TEST_TOKEN:
      case symbol_kind::S_INDIRECT_MEMBER:
      case symbol_kind::S_IDENTIFIER:
      case symbol_kind::S_STRING_LITERAL:
      case symbol_kind::S_NUMERIC_LITERAL:
      case symbol_kind::S_REAL_LITERAL:
      case symbol_kind::S_CHAR_LITERAL:
      case symbol_kind::S_HEXADECIMAL_LITERAL:
      case symbol_kind::S_OCTAL_DECIMAL_LITERAL:
      case symbol_kind::S_compiler:
      case symbol_kind::S_file:
      case symbol_kind::S_stmt:
      case symbol_kind::S_if_expr:
      case symbol_kind::S_else_if_expr:
      case symbol_kind::S_else_expr:
      case symbol_kind::S_expr:
      case symbol_kind::S_function_call:
      case symbol_kind::S_function_decel:
      case symbol_kind::S_params_list:
      case symbol_kind::S_decel_list:
      case symbol_kind::S_decel:
      case symbol_kind::S_modifiers:
      case symbol_kind::S_type_modifier:
      case symbol_kind::S_rval:
      case symbol_kind::S_storage_class_specifier:
      case symbol_kind::S_type_specifier:
        value.copy< std::string > (std::move (that.value));
        break;

      default:
        break;
    }

  }




